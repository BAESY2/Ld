# LLM 프로바이더 선택: anthropic | openai_compatible | local
LLM_PROVIDER=anthropic

# Anthropic (정식 API 사용 시)
ANTHROPIC_API_KEY=
ANALYST_MODEL=claude-sonnet-4-6
ARCHITECT_MODEL=claude-opus-4-8
RENDERER_MODEL=claude-sonnet-4-6

# 자체 호스팅(vLLM/Ollama/TGI 등) 사용 시
LOCAL_BASE_URL=http://localhost:8000/v1

# 파이프라인 동작
TEMPERATURE=0
MAX_REVISIONS=3
USE_RAG=false
USE_Z3=true
