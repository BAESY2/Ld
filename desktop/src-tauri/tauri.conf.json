{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ladder Studio",
  "version": "0.1.0",
  "identifier": "com.ld.ladderstudio",
  "build": {
    "frontendDist": "../../frontend",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Ladder Studio — 자연어 PLC 설계",
        "width": 1480,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "url": "http://localhost:8000/studio.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/plc-backend"]
  }
}
