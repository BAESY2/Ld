{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PLC래더에디터",
  "version": "0.1.0",
  "identifier": "com.ld.plcladder",
  "build": {
    "frontendDist": "../../frontend",
    "devUrl": "http://localhost:8000",
